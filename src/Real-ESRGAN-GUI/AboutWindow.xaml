<Window x:Class="RealESRGAN_GUI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/window-icon.ico"
        Width="640"
        Height="600"
        MinWidth="640"
        MaxWidth="640"
        MinHeight="600"
        MaxHeight="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Microsoft YaHei UI, DengXian, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBlock Text="Real-ESRGAN GUI"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBlock x:Name="DescriptionText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            MinWidth="150"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <TextBlock x:Name="VersionLabelText"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               TextAlignment="Right"/>
                    <TextBlock x:Name="VersionValueText"
                               Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               TextAlignment="Right"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="LicenseSectionTitleText"
                           Grid.Row="0"
                           Style="{StaticResource SectionTitle}"/>

                <ComboBox x:Name="LicenseCombo"
                          Grid.Row="1"
                          Margin="0,10,0,10"
                          DisplayMemberPath="Title"
                          SelectionChanged="OnLicenseSelectionChanged"/>

                <TextBox x:Name="LicenseTextBox"
                         Grid.Row="2"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                         FontSize="12"
                         HorizontalScrollBarVisibility="Disabled"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        Grid.Row="2"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="RepositoryButton"
                        Style="{StaticResource AccentButton}"
                        Click="OnRepositoryClick"/>
                <Button x:Name="CloseButton"
                        Margin="10,0,0,0"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
