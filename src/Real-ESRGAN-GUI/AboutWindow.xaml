<Window x:Class="RealESRGAN_GUI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/window-icon.ico"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Microsoft YaHei UI, DengXian, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="Real-ESRGAN GUI"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBlock x:Name="DescriptionText"
                       Margin="0,6,0,18"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       TextWrapping="Wrap"/>

            <Border Style="{StaticResource Card}"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="VersionLabelText"
                               Grid.Column="0"
                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <TextBlock x:Name="VersionValueText"
                               Grid.Column="1"
                               Margin="18,0,0,0"
                               FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="RepositoryButton"
                        Style="{StaticResource AccentButton}"
                        Click="OnRepositoryClick"/>
                <Button x:Name="CloseButton"
                        Margin="10,0,0,0"
                        Click="OnCloseClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
