<Window x:Class="RealESRGAN_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RealESRGAN_GUI"
        Title="Real-ESRGAN GUI"
        Icon="/window-icon.ico"
        Width="860"
        MinWidth="460"
        MaxWidth="860"
        MinHeight="520"
        SizeToContent="Manual"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Microsoft YaHei UI, DengXian, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="HeaderIconButton" TargetType="local:HeaderActionControl">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="local:HeaderActionControl">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#46FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsActive" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderPreferenceComboBox" TargetType="local:HeaderPreferenceComboBox">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource HeaderForegroundBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="MaxDropDownHeight" Value="260"/>
            <Setter Property="local:ComboBoxMouseWheelBehavior.RouteClosedWheelToParent" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="local:HeaderPreferenceComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          Foreground="{TemplateBinding Foreground}"
                                          Tag="{TemplateBinding IconData}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Focusable="False">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Cursor" Value="Arrow"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Path Width="18"
                                                  Height="18"
                                                  Stretch="Uniform"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"
                                                  Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#46FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Custom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   CustomPopupPlacementCallback="{x:Static local:HeaderPreferenceComboBox.PreferencePopupPlacementCallback}">
                                <Border Style="{StaticResource DropdownPopupBorder}"
                                        MinWidth="150"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocusBorderVisible" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderIconPath" TargetType="Path">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:HeaderActionControl}}"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Fill" Value="Transparent"/>
        </Style>

        <Style x:Key="ScaleInfoButton" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="MinWidth" Value="18"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource RailBrush}"
                BorderBrush="{DynamicResource HeaderDividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,22">
            <Grid x:Name="HeaderGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderContentColumn" Width="*"/>
                    <ColumnDefinition x:Name="HeaderActionsColumn" Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="HeaderTitlePanel" Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Real-ESRGAN GUI" Style="{StaticResource AppTitle}"/>
                    <TextBlock x:Name="HeaderSubtitleText"
                               Text="图片清晰化工作台"
                               Style="{StaticResource HeroSubtitle}"
                               Margin="1,4,0,0"/>
                </StackPanel>

                <StackPanel x:Name="HeaderActionsPanel"
                            Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <local:HeaderPreferenceComboBox x:Name="ThemeCombo"
                                                    Style="{StaticResource HeaderPreferenceComboBox}"
                                                    IconData="M12 3 V5 M12 19 V21 M4.22 4.22 L5.64 5.64 M18.36 18.36 L19.78 19.78 M3 12 H5 M19 12 H21 M4.22 19.78 L5.64 18.36 M18.36 5.64 L19.78 4.22 M12 8 A4 4 0 1 1 12 16 A4 4 0 0 1 12 8"
                                                    SelectionChanged="OnThemeChanged"
                                                    Margin="0,0,8,0"/>

                    <local:HeaderPreferenceComboBox x:Name="LanguageCombo"
                                                    Style="{StaticResource HeaderPreferenceComboBox}"
                                                    IconData="M5 8 L11 14 M4 14 L10 8 L12 5 M2 5 H14 M7 2 H8 M22 22 L17 12 L12 22 M14 18 H20"
                                                    SelectionChanged="OnLanguageChanged"
                                                    Margin="0,0,8,0"/>

                    <local:HeaderActionControl x:Name="AboutButton"
                                               Style="{StaticResource HeaderIconButton}">
                        <Path Style="{StaticResource HeaderIconPath}"
                              Data="M12 16 V12 M12 8 H12.01 M22 12 A10 10 0 1 1 2 12 A10 10 0 0 1 22 12"/>
                    </local:HeaderActionControl>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="MainScrollViewer"
                      Grid.Row="1"
                      Margin="0,0,2,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <ScrollViewer.Resources>
                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource {x:Type ScrollBar}}">
                    <Style.Triggers>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter Property="Margin" Value="0,4,0,4"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Resources>
            <ScrollViewer.Template>
                <ControlTemplate TargetType="{x:Type ScrollViewer}">
                    <Grid Background="{TemplateBinding Background}" ClipToBounds="True">
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                CanHorizontallyScroll="False"
                                                CanVerticallyScroll="False"
                                                Content="{TemplateBinding Content}"
                                                ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                Margin="{TemplateBinding Padding}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   HorizontalAlignment="Right"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   Orientation="Vertical"
                                   Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </ScrollViewer.Template>
            <StackPanel Margin="28">
                <Grid x:Name="FoldersGrid" Margin="0,0,0,18">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="FoldersFirstRow" Height="Auto" />
                        <RowDefinition x:Name="FoldersRowGap" Height="0" />
                        <RowDefinition x:Name="FoldersSecondRow" Height="0" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="FoldersFirstColumn" Width="*"/>
                        <ColumnDefinition x:Name="FoldersColumnGap" Width="18"/>
                        <ColumnDefinition x:Name="FoldersSecondColumn" Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="InputCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StepBadge}" Margin="0,2,14,0">
                                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="0" Grid.Column="1">
                                <StackPanel>
                                    <TextBlock x:Name="InputTitleText"
                                               Text="图片来源"
                                               Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="InputSummaryText"
                                               Text="尚未选择文件夹"
                                               Style="{StaticResource HelperText}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBox Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     x:Name="InputPathBox"
                                     IsReadOnly="True"
                                     Margin="0,16,0,0"/>

                            <StackPanel Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,12,0,0">
                                <Button x:Name="BrowseInputButton"
                                        Content="选择图片文件夹"
                                        Click="OnBrowseInputClick"/>
                                <Button x:Name="OpenInputButton"
                                        Content="打开文件夹"
                                        Margin="10,0,0,0"
                                        Click="OnOpenInputClick"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="OutputCard" Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StepBadge}" Margin="0,2,14,0">
                                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Row="0" Grid.Column="1">
                                <StackPanel>
                                    <TextBlock x:Name="OutputTitleText"
                                               Text="保存位置"
                                               Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="OutputSummaryText"
                                               Text="处理结果会保存到这里"
                                               Style="{StaticResource HelperText}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBox Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     x:Name="OutputPathBox"
                                     IsReadOnly="True"
                                     Margin="0,16,0,0"/>

                            <StackPanel Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,12,0,0">
                                <Button x:Name="BrowseOutputButton"
                                        Content="选择保存文件夹"
                                        Click="OnBrowseOutputClick"/>
                                <Button x:Name="OpenOutputButton"
                                        Content="打开文件夹"
                                        Margin="10,0,0,0"
                                        Click="OnOpenOutputClick"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource StepBadge}" Margin="0,0,14,0">
                                <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="SettingsSectionTitleText"
                                       Text="处理方式"
                                       Style="{StaticResource SectionTitle}"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="2" x:Name="AdvancedToggle"
                                          Click="OnAdvancedToggleClick"
                                          Cursor="Hand"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          Foreground="{DynamicResource AccentBrush}"
                                          FontSize="13"
                                          Padding="4,2"
                                          VerticalAlignment="Center">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="AdvancedToggleLabelText"
                                               VerticalAlignment="Center"/>
                                    <Path x:Name="AdvancedToggleIndicator"
                                          Data="M 0 0 L 8 0 L 4 4 Z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                          Width="8"
                                          Height="4"
                                          Stretch="Fill"
                                          VerticalAlignment="Center"
                                          Margin="6,1,0,0"/>
                                </StackPanel>
                            </ToggleButton>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid x:Name="BasicSettingsGrid" Grid.Row="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="BasicSettingsFirstRow" Height="Auto"/>
                                    <RowDefinition x:Name="BasicSettingsSecondRowGap" Height="0"/>
                                    <RowDefinition x:Name="BasicSettingsSecondRow" Height="0"/>
                                    <RowDefinition x:Name="BasicSettingsThirdRowGap" Height="0"/>
                                    <RowDefinition x:Name="BasicSettingsThirdRow" Height="0"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="BasicSettingsFirstColumn" Width="1.15*"/>
                                    <ColumnDefinition x:Name="BasicSettingsFirstColumnGap" Width="16"/>
                                    <ColumnDefinition x:Name="BasicSettingsSecondColumn" Width="0.8*"/>
                                    <ColumnDefinition x:Name="BasicSettingsSecondColumnGap" Width="16"/>
                                    <ColumnDefinition x:Name="BasicSettingsThirdColumn" Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel x:Name="ModelField" Grid.Row="0" Grid.Column="0">
                                    <TextBlock x:Name="ModelLabelText"
                                               Text="图片类型"
                                               Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="ModelCombo"/>
                                </StackPanel>
                                <StackPanel x:Name="ScaleField" Grid.Row="0" Grid.Column="2">
                                    <TextBlock x:Name="ScaleLabelText"
                                               Text="放大倍数"
                                               Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <ComboBox x:Name="ScaleCombo"/>
                                        <Button x:Name="ScaleInfoIcon"
                                                Style="{StaticResource ScaleInfoButton}"
                                                Content="i"
                                                Focusable="False"
                                                HorizontalAlignment="Right"
                                                IsTabStop="False"
                                                VerticalAlignment="Top"
                                                Margin="0,-7,-7,0"
                                                Visibility="Collapsed"
                                                Panel.ZIndex="1"/>
                                        <Popup x:Name="ScaleInfoPopup"
                                               AllowsTransparency="True"
                                               Focusable="False"
                                               IsHitTestVisible="False"
                                               Placement="Custom"
                                               PlacementTarget="{Binding ElementName=ScaleInfoIcon}"
                                               StaysOpen="True"
                                               CustomPopupPlacementCallback="{x:Static local:MainWindow.ScaleInfoPopupPlacementCallback}">
                                            <Border Style="{StaticResource DropdownPopupBorder}"
                                                    Padding="10,9"
                                                    Width="280">
                                                <TextBlock x:Name="ScaleInfoPopupText"
                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </StackPanel>
                                <StackPanel x:Name="FormatField" Grid.Row="0" Grid.Column="4">
                                    <TextBlock x:Name="FormatLabelText"
                                               Text="保存格式"
                                               Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="FormatCombo"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    x:Name="AdvancedPanel"
                                    Visibility="Collapsed"
                                    Margin="0,18,0,0">
                                <Grid x:Name="AdvancedSettingsGrid">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition x:Name="AdvancedSettingsSecondRowGap" Height="0"/>
                                        <RowDefinition x:Name="AdvancedSettingsSecondRow" Height="0"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="AdvancedSettingsFirstColumn" Width="*"/>
                                        <ColumnDefinition x:Name="AdvancedSettingsColumnGap" Width="16"/>
                                        <ColumnDefinition x:Name="AdvancedSettingsSecondColumn" Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel x:Name="ThreadsField" Grid.Row="0" Grid.Column="0">
                                        <TextBlock x:Name="ThreadsLabelText"
                                                   Text="线程数"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="ThreadsCombo"/>
                                    </StackPanel>
                                    <StackPanel x:Name="GpuField" Grid.Row="0" Grid.Column="2">
                                        <TextBlock x:Name="GpuLabelText"
                                                   Text="GPU 设备"
                                                   Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="GpuCombo"/>
                                    </StackPanel>
                                    <CheckBox Grid.Row="3"
                                              Grid.ColumnSpan="3"
                                              x:Name="TtaCheck"
                                              Content="质量增强（较慢）"
                                              Margin="0,16,0,0"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,18,0,0">
                                <TextBlock x:Name="HintText"
                                           Text="请先根据图片内容选择类型，模型不匹配可能影响效果；其余设置保持默认即可。"
                                           Foreground="{DynamicResource AccentBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource StepBadge}" Margin="0,0,14,0">
                                <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="StartTitleText"
                                       Text="开始处理"
                                       Style="{StaticResource SectionTitle}"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="2" x:Name="LogToggle"
                                          Click="OnLogToggleClick"
                                          Cursor="Hand"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          Foreground="{DynamicResource AccentBrush}"
                                          FontSize="13"
                                          Padding="4,2"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Visibility="Collapsed">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="LogToggleLabelText"
                                               VerticalAlignment="Center"/>
                                    <Path x:Name="LogToggleIndicator"
                                          Data="M 0 0 L 8 0 L 4 4 Z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                          Width="8"
                                          Height="4"
                                          Stretch="Fill"
                                          VerticalAlignment="Center"
                                          Margin="6,1,0,0"/>
                                </StackPanel>
                            </ToggleButton>
                            <TextBlock Grid.Column="3"
                                       x:Name="ProgressPercentText"
                                       Text="0%"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="1"
                              x:Name="ProgressTrack"
                              Margin="0,14,0,10">
                            <ProgressBar x:Name="CompletedProgressBar"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0"
                                         Foreground="{DynamicResource ProgressCurrentBrush}"/>
                            <ProgressBar x:Name="CurrentFileProgressBar"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource ProgressCompleteBrush}"
                                         Opacity="0.78"
                                         Panel.ZIndex="1"
                                         Visibility="Collapsed"/>
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   x:Name="StatusText"
                                   Text="就绪"
                                   Style="{StaticResource HelperText}"
                                   Margin="0,0,0,14"/>

                        <Border Grid.Row="3"
                                x:Name="LogPanel"
                                Visibility="Collapsed"
                                Margin="0"
                                Background="{DynamicResource ControlBrush}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource PanelBrush}"
                                        CornerRadius="8,8,0,0"
                                        Padding="12,8"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <TextBlock x:Name="LogHeaderText"
                                               Text="输出日志"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                                              MaxHeight="300"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock x:Name="LogText"
                                               FontFamily="Consolas, monospace"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               Margin="12,10"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="RunButtonsPanel" Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="StartButton"
                                    Content="开始清晰化"
                                    Style="{StaticResource AccentButton}"
                                    MinWidth="150"
                                    Click="OnStartClick"/>
                            <Button x:Name="StopButton"
                                    Content="停止"
                                    Style="{StaticResource DangerButton}"
                                    Margin="10,0,0,0"
                                    IsEnabled="False"
                                    Click="OnStopClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
