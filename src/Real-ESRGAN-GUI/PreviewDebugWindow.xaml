<Window x:Class="RealESRGAN_GUI.PreviewDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/window-icon.ico"
        Width="520"
        MinWidth="520"
        MaxWidth="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Microsoft YaHei UI, DengXian, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Border Padding="22"
            Background="{DynamicResource BgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundBrush}"/>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="UpdateCheckTitleText"
                               Grid.Row="0"
                               Style="{StaticResource SectionTitle}"/>

                    <Grid Grid.Row="1"
                          Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="132"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="CurrentVersionLabelText"
                                   Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,14,8"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock x:Name="CurrentVersionValueText"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="0,0,0,8"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="SimulatedLatestVersionLabelText"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,14,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBox x:Name="SimulatedLatestVersionTextBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,0,0,8"/>

                        <TextBlock x:Name="LatestVersionLabelText"
                                   Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,14,8"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock x:Name="LatestVersionValueText"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="StatusLabelText"
                                   Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,0,14,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock x:Name="StatusValueText"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock x:Name="LatestReleaseLinkText"
                               Grid.Row="2"
                               Margin="0,12,0,0"
                               Visibility="Collapsed">
                        <Hyperlink Foreground="{DynamicResource AccentBrush}"
                                   Click="OnLatestReleaseClick">
                            <Run x:Name="LatestReleaseLinkRun"/>
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2"
                        Margin="0,20,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="SimulateUpdateAvailableButton"
                        Style="{StaticResource AccentButton}"
                        Click="OnSimulateUpdateAvailableClick"/>
                <Button x:Name="CloseButton"
                        Margin="10,0,0,0"
                        MinHeight="48"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
