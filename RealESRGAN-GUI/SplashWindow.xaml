<Window x:Class="RealESRGAN_GUI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        Height="220"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Microsoft YaHei UI, DengXian, Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextRenderingMode="ClearType">
    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Real-ESRGAN"
                           FontSize="28"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="StatusText"
                           Text="正在启动..."
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Height="6" Margin="0,24,0,0" ClipToBounds="True">
                <Border Background="{DynamicResource ProgressTrackBrush}"
                        CornerRadius="3"/>
                <Border x:Name="Pulse"
                        Width="92"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="3"
                        HorizontalAlignment="Left">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="PulseTransform" X="-92"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="PulseTransform"
                                     Storyboard.TargetProperty="X"
                                     From="-92"
                                     To="340"
                                     Duration="0:0:1.15"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
